@page "/equipo"
@inject NavigationManager Nav

<div class="min-h-screen bg-gray-950 text-gray-100 font-sans pb-20">
    
    @* --- HEADER / NAV --- *@
    <div class="max-w-7xl mx-auto px-6 pt-8 flex justify-between items-center">
        <button @onclick='() => Nav.NavigateTo("/")' class="flex items-center gap-2 text-gray-500 hover:text-blue-400 transition-colors group">
            <Icon Name="IconName.ArrowLeft" />
            <span class="text-xs font-black uppercase tracking-widest">Regresar a Estación</span>
        </button>
        <div class="text-right">
            <p class="text-[10px] font-black text-blue-500 uppercase tracking-[0.3em]">División de Ingeniería</p>
            <p class="text-xs text-gray-600 font-mono">ID: ALPHA-POLARIS-2026</p>
        </div>
    </div>

    @* --- TITULO --- *@
    <div class="max-w-7xl mx-auto px-6 mt-16 text-center">
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-white mb-4">
            UNIDAD DE <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-500">DESARROLLO</span>
        </h2>
        <p class="text-gray-500 max-w-2xl mx-auto text-sm md:text-base leading-relaxed">
            Personal especializado responsable del mantenimiento, despliegue y optimización del ecosistema digital POLARIS.
        </p>
    </div>

    @* --- GRID DE INTEGRANTES --- *@
    <div class="max-w-6xl mx-auto px-6 mt-20">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            
            @* Brian - Lead *@
            <div class="team-card group">
                <div class="relative z-10">
                    <div class="w-16 h-16 bg-blue-600/20 border border-blue-500/40 rounded-xl mb-6 flex items-center justify-center text-blue-400 group-hover:bg-blue-600 group-hover:text-white transition-all duration-500">
                        <Icon Name="IconName.Cpu" Size="IconSize.x2" />
                    </div>
                    <h4 class="text-lg font-bold text-white leading-tight">Brian Eduardo Cruz Olmedo</h4>
                    <p class="text-blue-500 text-[10px] font-black uppercase mt-2 tracking-widest">Software Lead</p>
                </div>
                <div class="absolute bottom-0 right-0 p-4 opacity-10 group-hover:opacity-30 transition-opacity">
                    <span class="text-4xl font-black italic">01</span>
                </div>
            </div>

            @* Abel *@
            <div class="team-card group">
                <div class="relative z-10">
                    <div class="w-16 h-16 bg-indigo-600/20 border border-indigo-500/40 rounded-xl mb-6 flex items-center justify-center text-indigo-400 group-hover:bg-indigo-600 group-hover:text-white transition-all duration-500">
                        <Icon Name="IconName.CodeSlash" Size="IconSize.x2" />
                    </div>
                    <h4 class="text-lg font-bold text-white leading-tight">Abel Gil Zamora</h4>
                    <p class="text-indigo-400 text-[10px] font-black uppercase mt-2 tracking-widest">Core Developer</p>
                </div>
                <div class="absolute bottom-0 right-0 p-4 opacity-10 group-hover:opacity-30 transition-opacity">
                    <span class="text-4xl font-black italic">02</span>
                </div>
            </div>

            @* Julián *@
            <div class="team-card group">
                <div class="relative z-10">
                    <div class="w-16 h-16 bg-cyan-600/20 border border-cyan-500/40 rounded-xl mb-6 flex items-center justify-center text-cyan-400 group-hover:bg-cyan-600 group-hover:text-white transition-all duration-500">
                        <Icon Name="IconName.ShieldCheck" Size="IconSize.x2" />
                    </div>
                    <h4 class="text-lg font-bold text-white leading-tight">Julián Álvarez Roque</h4>
                    <p class="text-cyan-400 text-[10px] font-black uppercase mt-2 tracking-widest">Systems Support</p>
                </div>
                <div class="absolute bottom-0 right-0 p-4 opacity-10 group-hover:opacity-30 transition-opacity">
                    <span class="text-4xl font-black italic">03</span>
                </div>
            </div>

            @* Cesar *@
            <div class="team-card group">
                <div class="relative z-10">
                    <div class="w-16 h-16 bg-slate-600/20 border border-slate-500/40 rounded-xl mb-6 flex items-center justify-center text-slate-400 group-hover:bg-slate-600 group-hover:text-white transition-all duration-500">
                        <Icon Name="IconName.TerminalFill" Size="IconSize.x2" />
                    </div>
                    <h4 class="text-lg font-bold text-white leading-tight">Cesar Alejandro Molina Bautista</h4>
                    <p class="text-slate-400 text-[10px] font-black uppercase mt-2 tracking-widest">Systems Support</p>
                </div>
                <div class="absolute bottom-0 right-0 p-4 opacity-10 group-hover:opacity-30 transition-opacity">
                    <span class="text-4xl font-black italic">04</span>
                </div>
            </div>

        </div>
    </div>

    @* --- TECH STACK SECTION --- *@
    <div class="max-w-4xl mx-auto px-6 mt-32">
        <div class="bg-gray-900/50 border border-gray-800 rounded-3xl p-8 backdrop-blur-md">
            <div class="flex items-center gap-4 mb-8">
                <div class="h-px flex-1 bg-gray-800"></div>
                <h3 class="text-xs font-black text-gray-500 uppercase tracking-[0.4em]">Arquitectura del Sistema</h3>
                <div class="h-px flex-1 bg-gray-800"></div>
            </div>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
                <div>
                    <p class="text-blue-500 font-bold mb-1">Blazor</p>
                    <p class="text-[10px] text-gray-600 uppercase">Frontend Engine</p>
                </div>
                <div>
                    <p class="text-blue-500 font-bold mb-1">.NET 10</p>
                    <p class="text-[10px] text-gray-600 uppercase">Core Runtime</p>
                </div>
                <div>
                    <p class="text-blue-500 font-bold mb-1">Tailwind CSS</p>
                    <p class="text-[10px] text-gray-600 uppercase">Design System</p>
                </div>
                <div>
                    <p class="text-blue-500 font-bold mb-1">Entity Framework</p>
                    <p class="text-[10px] text-gray-600 uppercase">Data Access</p>
                </div>
            </div>
        </div>
    </div>

</div>

<style>
    .team-card {
        position: relative;
        background-color: #111827;
        border: 1px solid #1f2937;
        border-radius: 1.5rem;
        padding: 2rem;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        height: 100%;
    }

        .team-card:hover {
            transform: translateY(-8px);
            border-color: #3b82f6;
            box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.7);
        }

        /* Efecto de brillo en el hover */
        .team-card::after {
            content: "";
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient( 90deg, transparent, rgba(59, 130, 246, 0.05), transparent );
            transition: 0.5s;
        }

        .team-card:hover::after {
            left: 100%;
        }
</style>