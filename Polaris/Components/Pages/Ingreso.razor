@using Polaris.Data
@using Polaris.Modelo
@using System.ComponentModel.DataAnnotations
@using System.Reflection
@using System.ComponentModel

@code {
    public UsuarioLogin usuario { get; set; } = new();
    private EditContext? editContext;
    [Parameter]
    public EventCallback<UsuarioLogin> eventLogin { get; set; }
    [Parameter]
    public EventCallback<string> eventValidarCorreo { get; set; }
    [Parameter]
    public EventCallback eventRegistar { get; set; }
    private string GetDisplayName(string propertyName)
    {
        var property = typeof(UsuarioLogin).GetProperty(propertyName);
        var attribute = property?.GetCustomAttributes(typeof(DisplayNameAttribute), true)
                .Cast<DisplayNameAttribute>()
                .FirstOrDefault();
        return attribute?.DisplayName ?? propertyName;
    }
    protected override void OnInitialized()
    {
        editContext = new EditContext(usuario);
        base.OnInitialized();
    }
    public async Task HandleOnValidSubmit()
    {
        if (editContext!.Validate())
        {
            await eventLogin.InvokeAsync(usuario);
        }
    }
    public async Task ValidarCorreoExistente(string email)
    {
        
        await eventValidarCorreo.InvokeAsync(email);
        
    }
    private async Task ResetForm()
    {
        usuario = new();
        editContext = new EditContext(usuario);
    }
    
}
<EditForm EditContext="@editContext" class="login-container  p-4   mx-auto" style="max-width: 500px;">
    <DataAnnotationsValidator />
 

    @* Campo de Email *@
    <div class="form-group row mb-3 align-items-center">
        <label class="col-12 col-md-4 col-form-label fw-bold">
            @GetDisplayName(nameof(usuario.Email)): <span class="text-danger">*</span>
        </label>
        <div class="col">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                <TextInput @bind-Value="@usuario.Email"
                           Placeholder="ejemplo@correo.com"
                           class="form-control" />
            </div>
            <ValidationMessage For="@(() => usuario.Email)" class="small" />
        </div>
    </div>

    @* Campo de Password *@
    <div class="form-group row mb-4 align-items-center">
        <label class="col-12 col-md-4 col-form-label fw-bold">
            @GetDisplayName(nameof(usuario.Password)): <span class="text-danger">*</span>
        </label>
        <div class="col">
            <div class="input-group">
                <PasswordInput @bind-Value="@usuario.Password"
                               Placeholder="Tu contraseña"
                               class="form-control" />
            </div>
            <div class="form-text text-end">
                <a href="/recuperar" class="text-decoration-none small">¿Olvidaste tu contraseña?</a>
            </div>
            <ValidationMessage For="@(() => usuario.Password)" class="small" />
        </div>
    </div>
    
    @* Botones de Acción *@
    <div class="d-grid gap-2 d-md-flex justify-content-md-end border-top pt-3">
        <Button Color="ButtonColor.Secondary" Outline="true" @onclick="ResetForm" class="px-4">
            Limpiar
        </Button>
        <Button Color="ButtonColor.Success" @onclick="HandleOnValidSubmit" class="px-5 fw-bold">
            Ingresar
        </Button>
    </div>

    @* Opción de registro para usuarios nuevos *@
    <div class="text-center mt-4 pt-2 border-top">
        <span class="text-muted">¿No tienes cuenta?</span>
        <a href="" class="fw-bold text-success text-decoration-none ms-1">Regístrate aquí</a>
    </div>
</EditForm>