@page "/gestionador-trabajos"
@using Polaris.Constants
@using Polaris.Servicio
@using Polaris.Modelo
@inject TrabajoService Servicio
@inject UsuarioService Usuario
<div class="min-h-screen bg-gray-950 px-6 py-12 text-gray-100 font-sans">
    <div class="max-w-7xl mx-auto">
        
        @* HEADER DEL MÓDULO *@
        <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-gray-800 pb-8">
            <div>
                <div class="inline-flex items-center gap-2 bg-blue-600/10 border border-blue-500/30 rounded-full px-3 py-1 mb-3">
                    <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
                    <span class="text-blue-300 text-xs font-bold tracking-widest uppercase">Módulo Administrativo</span>
                </div>
                <h3 class="text-4xl font-black text-white tracking-tight">
                    Gestión de <span class="text-blue-400">Trabajos y Eventos</span>
                </h3>
                <p class="text-gray-400 mt-2 max-w-2xl">Optimiza la tripulación y los cronogramas de los proyectos activos en la estación POLARIS.</p>
            </div>
        </div>

        @if (trabajoDetalle == null)
        {
            @* FORMULARIO (CREATE / UPDATE) *@
            <div class="bg-gray-900 rounded-3xl shadow-2xl border border-gray-800 p-8 mb-12 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-1 h-full bg-blue-600"></div>
                <h4 class="text-xl font-bold text-white mb-8 flex items-center gap-3">
                    <Icon Name="@(isEditando ? IconName.PencilSquare : IconName.PlusCircleFill)" Class="text-blue-500" />
                    @(isEditando ? "Editar Registro Existente" : "Crear Nuevo Trabajo / Evento")
                </h4>
                <EditForm>
                    <DataAnnotationsValidator/>
                <div class="grid-layout">
                    <div class="span-4">
                        <label class="custom-label">Nombre del Proyecto</label>
                        <input type="text" class="custom-input" @bind="trabajoForm.Nombre" placeholder="Ej: Misión Artemis II" />
                        <ValidationMessage For="@(() => trabajoForm.Nombre)" class="text-red-500 text-sm mt-1" />
                    </div>

                    <div class="span-3">
                        <label class="custom-label">Categoría</label>
                        <select class="custom-input" @bind="trabajoForm.TipoTrabajo">
                            <option value="">Seleccione tipo...</option>
                            @foreach (var estado in TipoEvento.Tipos)
                            {
                                <option value="@estado">@estado</option>
                            }
                        </select>
                        <ValidationMessage For="@(() => trabajoForm.TipoTrabajo)" class="text-red-500 text-sm mt-1" />
                    </div>

                    <div class="span-5">
                        <label class="custom-label">Descripción Breve</label>
                        <input type="text" class="custom-input" @bind="trabajoForm.Descripcion" placeholder="Describe el objetivo..." />
                        <ValidationMessage For="@(() => trabajoForm.Descripcion)" class="text-red-500 text-sm mt-1" />
                    </div>

                    <div class="span-3">
                        <label class="custom-label">Inicio Registro</label>
                        <input type="date" class="custom-input" @bind="trabajoForm.FechaInicioRegistro" />
                        <ValidationMessage For="@(() => trabajoForm.FechaInicioRegistro)" class="text-red-500 text-sm mt-1" />
                    </div>
                    <div class="span-3">
                        <label class="custom-label">Fin Registro</label>
                        <input type="date" class="custom-input" @bind="trabajoForm.FechaFinRegistro" />
                        <ValidationMessage For="@(() => trabajoForm.FechaFinRegistro)" class="text-red-500 text-sm mt-1" />
                    </div>
                    <div class="span-3">
                        <label class="custom-label">Inicio Ejecución</label>
                        <input type="date" class="custom-input" @bind="trabajoForm.FechaInicioTrabajo" />
                        <ValidationMessage For="@(() => trabajoForm.FechaInicioTrabajo)" class="text-red-500 text-sm mt-1" />
                    </div>
                    <div class="span-3">
                        <label class="custom-label">Fin Ejecución</label>
                        <input type="date" class="custom-input" @bind="trabajoForm.FechaFinTrabajo" />
                        <ValidationMessage For="@(() => trabajoForm.FechaFinTrabajo)" class="text-red-500 text-sm mt-1" />
                    </div>

                    <div class="span-12 flex justify-end gap-3 mt-4">
                        @if (isEditando)
                        {
                            <button class="btn-secondary" @onclick="CancelarEdicion">Cancelar</button>
                            <button class="btn-primary bg-indigo-600" @onclick="GuardarCambios">Actualizar Datos</button>
                        }
                        else
                        {
                            <button class="btn-primary bg-blue-600" @onclick="CrearTrabajo">
                                <Icon Name="IconName.PlusLg" /> Crear Registro
                            </button>
                        }
                    </div>
                </div>
                
                </EditForm>
            </div>

            @* TABLA DE VISUALIZACIÓN (READ) *@
            <div class="bg-gray-900 rounded-3xl shadow-2xl border border-gray-800 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-800/50 border-b border-gray-800">
                                <th class="table-th">ID</th>
                                <th class="table-th">Información</th>
                                <th class="table-th text-center">Estado</th>
                                <th class="table-th">Participantes</th>
                                <th class="table-th">Fechas</th>
                                <th class="table-th text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-800">
                            @foreach (var t in trabajos)
                            {
                                <tr class="hover:bg-blue-900/10 transition-colors">
                                    <td class="px-6 py-5 font-mono text-blue-500 text-sm">#@t.Id</td>
                                    <td class="px-6 py-5">
                                        <div class="font-bold text-white text-lg">@t.Nombre</div>
                                        <span class="text-[10px] uppercase font-black bg-blue-900/40 text-blue-300 px-2 py-0.5 rounded border border-blue-800/50">@t.TipoTrabajo</span>
                                    </td>
                                    <td class="px-6 py-5 text-center">
                                        @{
                                            var estadoStr = EstadoEvento.Estado(t.FechaInicioRegistro, t.FechaFinRegistro, t.FechaInicioTrabajo, t.FechaFinTrabajo);
                                            var isAbierto = estadoStr.Contains("Abierto");
                                        }
                                        <span class="status-badge @(isAbierto ? "status-open" : "status-closed")">
                                            @estadoStr
                                        </span>
                                    </td>
                                    <td class="px-6 py-5">
                                        <div class="flex items-center gap-2">
                                            <div class="w-8 h-8 rounded-full bg-gray-800 border border-gray-700 flex items-center justify-center text-xs font-bold text-blue-400">
                                                @t.Participantes.Count
                                            </div>
                                            <span class="text-xs text-gray-500 uppercase">miembros</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-5">
                                        <div class="text-[11px] text-gray-400 space-y-1">
                                            <div>Reg: @t.FechaInicioRegistro.ToShortDateString()</div>
                                            <div>Ejec: @t.FechaInicioTrabajo.ToShortDateString()</div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-5 text-center">
                                        <div class="flex justify-center gap-2">
                                            <button class="action-btn hover:bg-blue-600" title="Ver" @onclick="() => VerDetalles(t)">
                                                <Icon Name="IconName.EyeFill" />
                                            </button>
                                            <button class="action-btn hover:bg-indigo-600" title="Editar" @onclick="() => IniciarEdicion(t)">
                                                <Icon Name="IconName.PencilFill" />
                                            </button>
                                            <button class="action-btn hover:bg-red-600" @ondblclick="() => EliminarTrabajo(t.Id)">
                                                <Icon Name="IconName.Trash3Fill" />
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            @* VISTA DE DETALLES Y GESTIÓN DE PARTICIPANTES *@
            <div class="bg-gray-900 rounded-3xl shadow-2xl border border-gray-800 p-10 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-600 to-indigo-600"></div>
                
                <button class="text-blue-400 hover:text-blue-300 font-bold text-sm mb-8 flex items-center gap-2 group" @onclick="() => trabajoDetalle = null">
                    <Icon Name="IconName.ArrowLeft" Class="group-hover:-translate-x-1 transition-transform" /> Volver al listado
                </button>

                <div class="flex flex-col md:flex-row justify-between mb-10">
                    <div>
                        <h3 class="text-3xl font-black text-white">@trabajoDetalle.Nombre</h3>
                        <p class="text-gray-400 mt-1">@trabajoDetalle.Descripcion</p>
                    </div>
                </div>

                <div class="grid-layout">
                    @* Inscribir *@
                    <div class="span-6 bg-gray-800/30 rounded-2xl p-6 border border-gray-800">
                        <h5 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                            <Icon Name="IconName.PersonPlusFill" Class="text-green-500" /> Inscribir Nuevo Miembro
                        </h5>
                        
                        @if (EstadoEvento.isRegistroAbierto(trabajoDetalle.FechaInicioRegistro, trabajoDetalle.FechaFinRegistro))
                        {
                            <div class="flex gap-2">
                                <input class="custom-input" @bind="nuevoParticipanteId" placeholder="Matrícula del Usuario" />
                                <button class="btn-primary bg-green-600 hover:bg-green-500" @onclick="AgregarParticipante">Inscribir</button>
                            </div>
                        }
                        else
                        {
                            <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4 text-yellow-500 text-sm">
                                Inscripción cerrada actualmente.
                            </div>
                        }
                    </div>

                    @* Lista *@
                    <div class="span-6">
                        <h5 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                            <Icon Name="IconName.PeopleFill" Class="text-blue-500" /> Tripulación Asignada
                        </h5>
                        <div class="space-y-3 max-h-80 overflow-y-auto custom-scrollbar pr-2">
                            @foreach (var pId in trabajoDetalle.Participantes)
                            {
                                var user = Usuario.usuarios.FirstOrDefault(u => u.Id == pId);
                                <div class="bg-gray-800/50 border border-gray-800 rounded-xl p-4 flex justify-between items-center">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-blue-600/20 flex items-center justify-center font-bold text-blue-400 border border-blue-500/20 text-xs">
                                            @(user?.Name?[0] ?? '?')
                                        </div>
                                        <div>
                                            <div class="font-bold text-white text-sm">@(user?.Name ?? "N/A")</div>
                                            <div class="text-[10px] text-gray-500 font-mono">ID: @pId</div>
                                        </div>
                                    </div>
                                    <button class="text-gray-500 hover:text-red-400 transition-colors" @onclick="() => EliminarParticipante(pId)">
                                        <Icon Name="IconName.XCircleFill" />
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Clases de Soporte para Tailwind faltante */
    .grid-layout { display: grid; grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 1.5rem; }
    .span-3 { grid-column: span 12 / span 12; }
    .span-4 { grid-column: span 12 / span 12; }
    .span-5 { grid-column: span 12 / span 12; }
    .span-6 { grid-column: span 12 / span 12; }
    .span-12 { grid-column: span 12 / span 12; }

    @@media (min-width: 768px) {
        .span-3 { grid-column: span 3 / span 3; }
        .span-4 { grid-column: span 4 / span 4; }
        .span-5 { grid-column: span 5 / span 5; }
        .span-6 { grid-column: span 6 / span 6; }
    }

    .custom-label { display: block; font-size: 0.7rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; margin-left: 0.25rem; }
    .custom-input { width: 100%; background-color: #1f2937; border: 1px solid #374151; color: white; border-radius: 0.75rem; padding: 0.65rem 1rem; transition: all 0.2s; outline: none; }
    .custom-input:focus { border-color: #3b82f6; box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2); }

    .btn-primary { color: white; font-weight: 700; padding: 0.65rem 2rem; border-radius: 0.75rem; transition: all 0.2s; display: inline-flex; items-center: center; gap: 0.5rem; border: none; cursor: pointer; }
    .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
    .btn-secondary { background-color: #374151; color: white; font-weight: 700; padding: 0.65rem 2rem; border-radius: 0.75rem; border: none; cursor: pointer; }

    .table-th { padding: 1.25rem 1.5rem; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #6b7280; }
    .status-badge { inline-flex: flex; align-items: center; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.7rem; font-weight: 700; border: 1px solid currentColor; }
    .status-open { background-color: rgba(34, 197, 94, 0.1); color: #4ade80; }
    .status-closed { background-color: rgba(239, 68, 68, 0.1); color: #f87171; }

    .action-btn { padding: 0.5rem; background-color: #1f2937; color: #9ca3af; border-radius: 0.5rem; transition: all 0.2s; border: none; cursor: pointer; }
    .action-btn:hover { color: white; }

    .custom-scrollbar::-webkit-scrollbar { width: 5px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
</style>
@code {
    private Trabajo trabajoForm = new();
    private Trabajo? trabajoDetalle;
    private List<Trabajo> trabajos = new();
    private bool isEditando = false;
    private string nuevoParticipanteId = "";

    protected override async Task OnInitializedAsync()
    {
        await Usuario.Inicializar();
        RefrescarLista();
    }

    private void RefrescarLista() => trabajos = Servicio.Trabajos.ToList();

    private void CrearTrabajo()
    {
        if (string.IsNullOrWhiteSpace(trabajoForm.Nombre)) return;
        Servicio.AgregarTrabajo(trabajoForm);
        trabajoForm = new();
        RefrescarLista();
    }

    private void IniciarEdicion(Trabajo t)
    {
        // Clonamos para no editar la referencia de la lista directamente
        trabajoForm = t.Clone();
        isEditando = true;
    }

    private void GuardarCambios()
    {
        Servicio.ActualizarTrabajo(trabajoForm);
        CancelarEdicion();
        RefrescarLista();
    }

    private void CancelarEdicion()
    {
        trabajoForm = new();
        isEditando = false;
    }

    private void EliminarTrabajo(int id)
    {
        Servicio.EliminarTrabajo(id);
        RefrescarLista();
    }

    private void VerDetalles(Trabajo t)
    {
        trabajoDetalle = t;
        isEditando = false;
    }

    private void AgregarParticipante()
    {
        if (!string.IsNullOrEmpty(nuevoParticipanteId) && trabajoDetalle != null)
        {
            Servicio.AgregarParticipante(trabajoDetalle.Id, nuevoParticipanteId);
            nuevoParticipanteId = "";
        }
    }

    private void EliminarParticipante(string id)
    {
        if (trabajoDetalle != null)
        {
            Servicio.EliminarParticipante(trabajoDetalle.Id, id);
        }
    }
}