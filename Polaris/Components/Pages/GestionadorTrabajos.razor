@page "/gestionador-trabajos"
@using Polaris.Constants
@using Polaris.Servicio
@using Polaris.Modelo
@inject TrabajoService Servicio
@inject UsuarioService Usuario

<div class="min-h-screen bg-gray-50 px-4 py-8">
    <div class="max-w-7xl mx-auto">
        
        <div class="mb-8">
            <h3 class="text-3xl font-bold text-gray-800 tracking-tight">
                Gestión de Trabajos y Eventos
            </h3>
            <p class="text-gray-500 mt-1 text-sm">Administra registros, eventos y participantes del programa</p>
        </div>

        @if (trabajoDetalle == null)
        {
            <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-6 mb-8">
                <h4 class="text-lg font-semibold text-blue-600 mb-5 flex items-center gap-2">
                    <span class="inline-block w-2 h-2 rounded-full bg-blue-500"></span>
                    @(isEditando ? "Editar Trabajo" : "Nuevo Trabajo / Evento")
                </h4>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Nombre</label>
                        <input type="text" class="form-control rounded-lg border-gray-200 focus:ring-2 focus:ring-blue-400" @bind="trabajoForm.Nombre" />
                    </div>

                    <div class="col-md-3">
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Tipo</label>
                        <select class="form-select rounded-lg border-gray-200" @bind="trabajoForm.TipoTrabajo">
                            <option value="">Seleccione...</option>
                            @foreach (var estado in TipoEvento.Tipos)
                            {
                                <option value="@estado">@estado</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Descripción</label>
                        <input type="text" class="form-control rounded-lg border-gray-200" @bind="trabajoForm.Descripcion" />
                    </div>

                    <div class="col-md-3">
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Inicio Registro</label>
                        <input type="date" class="form-control rounded-lg border-gray-200" @bind="trabajoForm.FechaInicioRegistro" />
                    </div>
                    <div class="col-md-3">
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Fin Registro</label>
                        <input type="date" class="form-control rounded-lg border-gray-200" @bind="trabajoForm.FechaFinRegistro" />
                    </div>
                    <div class="col-md-3">
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Inicio @(trabajoForm.TipoTrabajo)</label>
                        <input type="date" class="form-control rounded-lg border-gray-200" @bind="trabajoForm.FechaInicioTrabajo" />
                    </div>
                    <div class="col-md-3">
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Fin @(trabajoForm.TipoTrabajo)</label>
                        <input type="date" class="form-control rounded-lg border-gray-200" @bind="trabajoForm.FechaFinTrabajo" />
                    </div>

                    <div class="col-12 text-end flex justify-end gap-2">
                        @if (isEditando)
                        {
                            <button class="btn btn-success rounded-lg px-5 font-semibold shadow-sm" @onclick="GuardarCambios">Guardar Cambios</button>
                            <button class="btn btn-secondary rounded-lg px-5 ms-2" @onclick="CancelarEdicion">Cancelar</button>
                        }
                        else
                        {
                            <button class="btn btn-primary rounded-lg px-6 font-semibold shadow-sm" @onclick="CrearTrabajo">Crear Registro</button>
                        }
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-gray-800 text-white">
                            <tr>
                                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-gray-300">ID</th>
                                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-gray-300">Nombre</th>
                                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-gray-300">Estado</th>
                                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-gray-300">Participantes</th>
                                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-gray-300">Fechas</th>
                                <th class="py-4 px-4 text-xs font-semibold uppercase tracking-wider text-gray-300 text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var t in trabajos)
                            {
                                <tr class="hover:bg-blue-50 transition-colors duration-150">
                                    <td class="px-4 py-3 text-gray-400 font-mono text-sm">#@t.Id</td>
                                    <td class="px-4 py-3">
                                        <span class="font-semibold text-gray-800">@t.Nombre</span>
                                        <br />
                                        <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">@t.TipoTrabajo</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="badge bg-cyan-100 text-cyan-800 rounded-full px-3 py-1 text-xs font-semibold">
                                            @(EstadoEvento.Estado(t.FechaInicioRegistro, t.FechaFinRegistro, t.FechaInicioTrabajo, t.FechaFinTrabajo))
                                        </span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="inline-flex items-center gap-1 text-sm text-gray-600">
                                            <span class="font-semibold text-gray-800">@t.Participantes.Count</span> personas
                                        </span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <small class="text-gray-500 text-xs">Reg: @t.FechaInicioRegistro.ToShortDateString() — @t.FechaFinRegistro?.ToShortDateString()</small>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <div class="flex justify-center gap-1">
                                            <button class="btn btn-sm btn-outline-secondary rounded-lg text-xs px-3" @onclick="() => VerDetalles(t)">Detalles</button>
                                            <button class="btn btn-sm btn-outline-info rounded-lg text-xs px-3" @onclick="() => IniciarEdicion(t)">Editar</button>
                                            <Tooltip Title="Doble clic para eliminar" Placement="TooltipPlacement.Top" Color="TooltipColor.Danger">
                                                <button class="btn btn-sm btn-outline-danger rounded-lg text-xs px-3" @ondblclick="() => EliminarTrabajo(t.Id)">Eliminar</button>
                                            </Tooltip>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
                <button class="inline-flex items-center gap-1 text-blue-600 hover:text-blue-800 text-sm font-medium mb-6 transition-colors" @onclick="() => trabajoDetalle = null">
                    ← Volver a la lista
                </button>
                <h3 class="text-2xl font-bold text-gray-800 mb-1">@trabajoDetalle.Nombre</h3>
                <div class="border-t border-gray-100 my-4"></div>

                <div class="row">
                    <div class="col-md-6">
                        <h5 class="font-semibold text-gray-700 mb-3">Inscribir Nuevo Participante</h5>
                        @if (EstadoEvento.isRegistroAbierto(trabajoDetalle.FechaInicioRegistro, trabajoDetalle.FechaFinRegistro))
                        {
                            <div class="input-group mb-3 rounded-xl overflow-hidden shadow-sm">
                                <input class="form-control border-gray-200" @bind="nuevoParticipanteId" placeholder="ID del Usuario" />
                                <button class="btn btn-success px-5 font-semibold" @onclick="AgregarParticipante">Inscribir</button>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning rounded-xl border-l-4 border-yellow-400 bg-yellow-50 text-yellow-800 text-sm">El periodo de registro ha finalizado.</div>
                        }
                    </div>

                    <div class="col-md-6">
                        <h5 class="font-semibold text-gray-700 mb-3">Lista de Participantes</h5>
                        <ul class="list-group rounded-xl overflow-hidden shadow-sm divide-y divide-gray-100">
                            @foreach (var pId in trabajoDetalle.Participantes)
                            {
                                var user = Usuario.usuarios.FirstOrDefault(u => u.Id == pId);
                                <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4 hover:bg-gray-50 transition-colors">
                                    <div>
                                        <span class="font-medium text-gray-800">@(user?.Name ?? "Usuario no encontrado")</span>
                                        <span class="text-xs text-gray-400 ms-2">(@pId)</span>
                                    </div>
                                    <button class="btn btn-sm btn-danger rounded-lg w-7 h-7 d-flex align-items-center justify-content-center p-0 text-xs" @onclick="() => EliminarParticipante(pId)">×</button>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
@code {
    private Trabajo trabajoForm = new();
    private Trabajo? trabajoDetalle;
    private List<Trabajo> trabajos = new();
    private bool isEditando = false;
    private string nuevoParticipanteId = "";

    protected override async Task OnInitializedAsync()
    {
        await Usuario.Inicializar();
        RefrescarLista();
    }

    private void RefrescarLista() => trabajos = Servicio.Trabajos.ToList();

    private void CrearTrabajo()
    {
        if (string.IsNullOrWhiteSpace(trabajoForm.Nombre)) return;
        Servicio.AgregarTrabajo(trabajoForm);
        trabajoForm = new();
        RefrescarLista();
    }

    private void IniciarEdicion(Trabajo t)
    {
        // Clonamos para no editar la referencia de la lista directamente
        trabajoForm = t.Clone();
        isEditando = true;
    }

    private void GuardarCambios()
    {
        Servicio.ActualizarTrabajo(trabajoForm);
        CancelarEdicion();
        RefrescarLista();
    }

    private void CancelarEdicion()
    {
        trabajoForm = new();
        isEditando = false;
    }

    private void EliminarTrabajo(int id)
    {
        Servicio.EliminarTrabajo(id);
        RefrescarLista();
    }

    private void VerDetalles(Trabajo t)
    {
        trabajoDetalle = t;
        isEditando = false;
    }

    private void AgregarParticipante()
    {
        if (!string.IsNullOrEmpty(nuevoParticipanteId) && trabajoDetalle != null)
        {
            Servicio.AgregarParticipante(trabajoDetalle.Id, nuevoParticipanteId);
            nuevoParticipanteId = "";
        }
    }

    private void EliminarParticipante(string id)
    {
        if (trabajoDetalle != null)
        {
            Servicio.EliminarParticipante(trabajoDetalle.Id, id);
        }
    }
}