@using Polaris.Data
@using Polaris.Modelo
@using System.ComponentModel
@using Polaris.Servicio
@inject UsuarioService usuarioService
@code {
    public UsuarioRegister usuario { get; set; } = new();
    private EditContext? editContext;
    [Parameter]
    public EventCallback<UsuarioRegister> eventRegister { get; set; }
    private string GetDisplayName(string propertyName)
    {
        var property = typeof(UsuarioRegister).GetProperty(propertyName);
        var attribute = property?.GetCustomAttributes(typeof(DisplayNameAttribute), true)
                 .Cast<DisplayNameAttribute>()
                 .FirstOrDefault();
        return attribute?.DisplayName ?? propertyName;
    }
    protected override void OnInitialized()
    {
        editContext = new EditContext(usuario);
        
        usuario.Habilidades ??= Array.Empty<TiposHabilidades>();
        base.OnInitialized();
    }
    public async Task HandleOnValidSubmit()
    {
        if (editContext!.Validate())
        {
            await eventRegister.InvokeAsync(usuario);
        }
    }
    private async Task ResetForm()
    {
        usuario = new();
        editContext = new EditContext(usuario);
    }
    private async Task SelecionarVideo()
    {
        switch (usuario.Proyecto)
        {
            case (int)TiposProyectos.PolariX:

                break;
            case (int)TiposProyectos.Mentes_en_Orbita:

                break;
            case (int)TiposProyectos.Hydronautas:

                break;
            default:

                break;
        };
    }
    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var archivo = e.File;
        // Llamas a la lógica de conversión aquí
        await usuario.HandleFileSelection(archivo);
    }
    private async Task<AutoCompleteDataProviderResult<string>> InstitutosDataProvider(AutoCompleteDataProviderRequest<string> request)
    {
        var listaInstitutos = usuarioService.usuarios.Select(u => u.Instituto).ToList();
        var items = listaInstitutos
         .Where(x => x.Contains(request.Filter.Value, StringComparison.InvariantCultureIgnoreCase))
         .ToList();

        return await Task.FromResult(new AutoCompleteDataProviderResult<string> { Data = items });
    }
    private async Task<AutoCompleteDataProviderResult<string>> LugaresDataProvider(AutoCompleteDataProviderRequest<string> request)
    {
        var listaLugares = usuarioService.usuarios.Select(u => u.Lugar_actual).ToList();
        var items = listaLugares
         .Where(x => x.Contains(request.Filter.Value, StringComparison.InvariantCultureIgnoreCase))
         .ToList();

        return await Task.FromResult(new AutoCompleteDataProviderResult<string> { Data = items });
    }
    private async Task<AutoCompleteDataProviderResult<string>> RolesDataProvider(AutoCompleteDataProviderRequest<string> request)
    {
        var listaRoles = usuarioService.usuarios.Select(u => u.Rol_actual).ToList();
        var items = listaRoles
         .Where(x => x.Contains(request.Filter.Value, StringComparison.InvariantCultureIgnoreCase))
         .ToList();

        return await Task.FromResult(new AutoCompleteDataProviderResult<string> { Data = items });
    }

}

<EditForm EditContext="@editContext" style="" class="mb-8 overflow-hidden">
    <DataAnnotationsValidator />
    
    <!-- Contenedor principal con Grid de Bootstrap -->
    <div class="row row-cols-1 row-cols-lg-2 g-3">
        
        <!-- Foto (Ocupa las 2 columnas en desktop para que resalte, o 1 si prefieres) -->
        <div class="col-lg-12">
            <label class="form-label fw-bold  text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.Foto)): <span class="text-danger">*</span></label>
            <div class="d-flex align-items-center gap-3">
                <InputFile OnChange="@(e => OnInputFileChange(e))" class="form-control" />
                <Image Src="@usuario.ImagenSrc" Style="max-width: 100px;"></Image>
            </div>
            <ValidationMessage For="@(() => usuario.Foto)" class="text-danger small" />
        </div>

        <!-- Nombre -->
        <div class="col">
            <label class="form-label text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.Name))</label>
            <TextInput @bind-Value="@usuario.Name" Placeholder="Ingrese su nombre" class="form-control" />
            <ValidationMessage For="@(() => usuario.Name)" class="text-danger small" />
        </div>

        <!-- Email -->
        <div class="col">
            <label class="form-label text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.Email))</label>
            <TextInput @bind-Value="@usuario.Email" Placeholder="correo@ejemplo.com" class="form-control" />
            <ValidationMessage For="@(() => usuario.Email)" class="text-danger small" />
        </div>

        <!-- Password -->
        <div class="col">
            <label class="form-label text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.Password))</label>
            <PasswordInput @bind-Value="@usuario.Password" class="form-control" />
            <ValidationMessage For="@(() => usuario.Password)" class="text-danger small" />
        </div>

        <!-- Confirm Password -->
        <div class="col">
            <label class="form-label text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.RPassword))</label>
            <PasswordInput @bind-Value="@usuario.RPassword" class="form-control" />
            <ValidationMessage For="@(() => usuario.RPassword)" class="text-danger small" />
        </div>

        <!-- Proyecto -->
        <div class="col">
            <label class="form-label text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.Proyecto))</label>
            <InputSelect @bind-Value="@usuario.Proyecto" class="form-select">
                @foreach (var item in Enum.GetValues<TiposProyectos>())
                {
                    <option value="@item">@item.GetDisplayName()</option>
                }
            </InputSelect>
        </div>

        <!-- Teléfono -->
        <div class="col">
            <label class="form-label text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.Telefono))</label>
            <TextInput @bind-Value="@usuario.Telefono" Placeholder="10 dígitos" class="form-control" />
        </div>

        <!-- Instituto -->
        <div class="col">
            <label class="form-label text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.Instituto))</label>
            <AutoComplete @bind-Value="@usuario.Instituto" TItem="string" DataProvider="InstitutosDataProvider" />
        </div>

        <!-- Carrera -->
        <div class="col">
            <label class="form-label text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.Carrera))</label>
            <InputSelect @bind-Value="@usuario.Carrera" class="form-select">
                @foreach (var item in Enum.GetValues<Tipos_Carreras>())
                {
                    <option value="@((int)item)">@item.GetDisplayName()</option>
                }
            </InputSelect>
        </div>

        <!-- Semestre -->
        <div class="col">
            <label class="form-label text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.Semestre))</label>
            <InputSelect @bind-Value="@usuario.Semestre" class="form-select">
                @foreach (var item in Enum.GetValues<Numero_Semestre>())
                {
                    <option value="@item">@item.GetDisplayName()</option>
                }
            </InputSelect>
        </div>

        <!-- Generación -->
        <div class="col">
            <label class="form-label text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.GenPolaris))</label>
            <InputSelect @bind-Value="@usuario.GenPolaris" class="form-select">
                @foreach (var item in Enum.GetValues<GeneracionesPol>())
                {
                    <option value="@item">@item.GetDisplayName()</option>
                }
            </InputSelect>
        </div>

        <!-- Habilidades (Ocupa 2 columnas en desktop por ser múltiple) -->
        <div class="col-lg-12">
            <label class="form-label text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.Habilidades))</label>
            <InputSelect @bind-Value="@usuario.Habilidades" class="form-select" multiple>
                @foreach (var item in Enum.GetValues<TiposHabilidades>())
                {
                    <option value="@item">@item.GetDisplayName()</option>
                }
            </InputSelect>
        </div>

        <!-- Interés (Checkbox) -->
        <div class="col-lg-12 d-flex align-items-center gap-2">
            <CheckboxInput @bind-Value="@usuario.Interes_Polaris" />
            <label class="form-check-label text-blue-400 uppercase tracking-widest ml-1">@GetDisplayName(nameof(usuario.Interes_Polaris))</label>
        </div>

    </div>

    <!-- Botones -->
    <div class="mt-4">
        <Button Color="ButtonColor.Success" @onclick="HandleOnValidSubmit"> Registrarme </Button>
        <Button Color="ButtonColor.Secondary" @onclick="ResetForm"> Limpiar </Button>
    </div>
</EditForm>