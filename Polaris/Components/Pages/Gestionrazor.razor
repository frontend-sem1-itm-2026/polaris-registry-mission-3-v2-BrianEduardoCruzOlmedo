@page "/gestion"
@using Polaris.Servicio
@using Polaris.Modelo
@using BlazorBootstrap   
@inject UsuarioService usuarioService
<Toasts class="p-3" Messages="messages" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />

@* El componente que hace aparecer la ventana de confirmación *@
<ConfirmDialog @ref="dialog" />

<div class="container mt-4">
    <a href="/" class="btn btn-outline-secondary mb-4 shadow-sm">
        <i class="bi bi-arrow-left"></i> Regresar a Inicio
    </a>

    <div class="d-flex align-items-center mb-4">
        <h2 class="text-primary mb-0"><i class="bi bi-people-fill me-2"></i> Gestión de Miembros (CRUD)</h2>
    </div>

    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Correo</th>
                <th>Rol</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (usuarioService.usuarios.Count == 0)
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">No hay usuarios cargados en memoria.</td>
                </tr>
            }
            else
            {
                @foreach (var user in usuarioService.usuarios)
                {
                    <tr>
                        <td class="align-middle">@user.Name</td>
                        <td class="align-middle">@user.Email</td>
                        <td class="align-middle">@user.Rol_actual</td>
                        <td>
                            <button class="btn btn-warning btn-sm mx-1" @onclick="() => PrepararEdicion(user)">
                                <i class="bi bi-pencil"></i> Editar
                            </button>
                            <button class="btn btn-danger btn-sm mx-1" @onclick="() => ConfirmarBorrado(user)">
                                <i class="bi bi-trash"></i> Eliminar
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    @if (modoEdicion)
    {
        <div class="card border-warning mt-4 shadow">
            <div class="card-header bg-warning text-dark fw-bold">
                Editando información de: @usuarioActual.Name
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Nombre:</label>
                        <input class="form-control" @bind="usuarioActual.Name" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Correo:</label>
                        <input class="form-control" @bind="usuarioActual.Email" type="email" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Rol:</label>
                        <input class="form-control" @bind="usuarioActual.Rol_actual" />
                    </div>
                </div>
                <div class="mt-2">
                    <button class="btn btn-success" @onclick="ConfirmarGuardado">Guardar Cambios</button>
                    <button class="btn btn-secondary" @onclick="() => modoEdicion = false">Cancelar</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private ConfirmDialog dialog = default!;
    private bool modoEdicion = false;
    private Usuario usuarioActual = new Usuario();
    List<ToastMessage> messages = new List<ToastMessage>();

    private void MostrarNotificacion(string titulo, string msj, bool exito)
    {
        messages.Add(new ToastMessage
        {
            Type = exito ? ToastType.Success : ToastType.Danger,
            Title = titulo,
            HelpText = $"{DateTime.Now:HH:mm:ss}",
            Message = msj
        });
    }

    protected override async Task OnInitializedAsync()
    {
        await usuarioService.Inicializar();
    }

    private void PrepararEdicion(Usuario user)
    {
        modoEdicion = true;
        usuarioActual = new Usuario
        {
            Id = user.Id,
            Name = user.Name,
            Email = user.Email,
            Rol_actual = user.Rol_actual
        };
    }

    // --- NUEVO: CONFIRMACIÓN PARA GUARDAR ---
    private async Task ConfirmarGuardado()
    {
        var opciones = new ConfirmDialogOptions
        {
            YesButtonText = "Sí, guardar",
            NoButtonText = "No, cancelar",
            YesButtonColor = ButtonColor.Success
        };

        var confirmado = await dialog.ShowAsync(
            title: "¿Confirmar cambios?",
            message1: $"¿Estás seguro que quieres actualizar los datos de {usuarioActual.Name}?",
            confirmDialogOptions: opciones);

        if (confirmado)
        {
            var resultado = await usuarioService.ActualizarUsuario(usuarioActual);
            MostrarNotificacion(resultado.title, resultado.msj, resultado.state);
            modoEdicion = false;
        }
    }

    // --- NUEVO: CONFIRMACIÓN PARA BORRAR ---
    private async Task ConfirmarBorrado(Usuario user)
    {
        var opciones = new ConfirmDialogOptions
        {
            YesButtonText = "Sí, eliminar",
            NoButtonText = "No, regresar",
            YesButtonColor = ButtonColor.Danger
        };

        var confirmado = await dialog.ShowAsync(
            title: "¡Advertencia de eliminación!",
            message1: $"¿Estás completamente seguro de eliminar a {user.Name}?",
            message2: "Esta acción no se puede deshacer.",
            confirmDialogOptions: opciones);

        if (confirmado)
        {
            var resultado = await usuarioService.EliminarUsuario(user.Id);
            MostrarNotificacion(resultado.title, resultado.msj, resultado.state);
        }
    }
}