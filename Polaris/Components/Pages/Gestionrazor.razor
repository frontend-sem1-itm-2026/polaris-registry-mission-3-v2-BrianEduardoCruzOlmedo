@page "/gestion"
@using Polaris.Servicio
@using Polaris.Modelo
@using BlazorBootstrap
@inject UsuarioService usuarioService

<Toasts class="p-3" Messages="messages" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />
<ConfirmDialog @ref="dialog" />

<div class="min-h-screen bg-gray-50 px-4 py-8">
    <div class="max-w-6xl mx-auto">

        <a href="/" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 font-medium mb-6 transition-colors bg-white border border-gray-200 rounded-xl px-4 py-2 shadow-sm hover:shadow-md">
            <i class="bi bi-arrow-left"></i> Regresar a Inicio
        </a>

        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-blue-600 flex items-center justify-center">
                <i class="bi bi-people-fill text-white text-lg"></i>
            </div>
            <div>
                <h2 class="text-2xl font-bold text-gray-800 mb-0">Gestión de Miembros</h2>
                <p class="text-gray-400 text-sm">CRUD de usuarios del programa</p>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden mb-6">
            <table class="table table-striped table-hover mb-0">
                <thead class="bg-gray-800 text-white">
                    <tr>
                        <th class="py-4 px-5 text-xs font-semibold uppercase tracking-wider text-gray-300">Nombre</th>
                        <th class="py-4 px-5 text-xs font-semibold uppercase tracking-wider text-gray-300">Correo</th>
                        <th class="py-4 px-5 text-xs font-semibold uppercase tracking-wider text-gray-300">Rol</th>
                        <th class="py-4 px-5 text-xs font-semibold uppercase tracking-wider text-gray-300">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @if (usuarioService.usuarios.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-center text-gray-400 py-12 text-sm italic">No hay usuarios cargados en memoria.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in usuarioService.usuarios)
                        {
                            <tr class="hover:bg-blue-50 transition-colors duration-150">
                                <td class="align-middle px-5 py-3 font-medium text-gray-800">@user.Name</td>
                                <td class="align-middle px-5 py-3 text-gray-500 text-sm">@user.Email</td>
                                <td class="align-middle px-5 py-3">
                                    <span class="bg-indigo-100 text-indigo-700 text-xs font-semibold px-3 py-1 rounded-full">@user.Rol_actual</span>
                                </td>
                                <td class="align-middle px-5 py-3">
                                    <div class="flex gap-2">
                                        <button class="btn btn-warning btn-sm rounded-lg px-3 font-medium shadow-sm" @onclick="() => PrepararEdicion(user)">
                                            <i class="bi bi-pencil me-1"></i> Editar
                                        </button>
                                        <button class="btn btn-danger btn-sm rounded-lg px-3 font-medium shadow-sm" @onclick="() => ConfirmarBorrado(user)">
                                            <i class="bi bi-trash me-1"></i> Eliminar
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (modoEdicion)
        {
            <div class="bg-white rounded-2xl shadow-xl border-l-4 border-yellow-400 overflow-hidden">
                <div class="bg-yellow-50 border-b border-yellow-100 px-6 py-4">
                    <p class="font-semibold text-yellow-800 text-sm mb-0">
                        <i class="bi bi-pencil-square me-2"></i> Editando información de: <span class="font-bold">@usuarioActual.Name</span>
                    </p>
                </div>
                <div class="p-6">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Nombre</label>
                            <input class="form-control rounded-lg border-gray-200" @bind="usuarioActual.Name" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Correo</label>
                            <input class="form-control rounded-lg border-gray-200" @bind="usuarioActual.Email" type="email" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Rol</label>
                            <input class="form-control rounded-lg border-gray-200" @bind="usuarioActual.Rol_actual" />
                        </div>
                    </div>
                    <div class="flex gap-2 mt-2">
                        <button class="btn btn-success rounded-lg px-5 font-semibold shadow-sm" @onclick="ConfirmarGuardado">Guardar Cambios</button>
                        <button class="btn btn-secondary rounded-lg px-5" @onclick="() => modoEdicion = false">Cancelar</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private ConfirmDialog dialog = default!;
    private bool modoEdicion = false;
    private Usuario usuarioActual = new Usuario();
    List<ToastMessage> messages = new List<ToastMessage>();

    private void MostrarNotificacion(string titulo, string msj, bool exito)
    {
        messages.Add(new ToastMessage
        {
            Type = exito ? ToastType.Success : ToastType.Danger,
            Title = titulo,
            HelpText = $"{DateTime.Now:HH:mm:ss}",
            Message = msj
        });
    }

    protected override async Task OnInitializedAsync()
    {
        await usuarioService.Inicializar();
    }

    private void PrepararEdicion(Usuario user)
    {
        modoEdicion = true;
        usuarioActual = new Usuario
        {
            Id = user.Id,
            Name = user.Name,
            Email = user.Email,
            Rol_actual = user.Rol_actual
        };
    }

    // --- NUEVO: CONFIRMACIÓN PARA GUARDAR ---
    private async Task ConfirmarGuardado()
    {
        var opciones = new ConfirmDialogOptions
        {
            YesButtonText = "Sí, guardar",
            NoButtonText = "No, cancelar",
            YesButtonColor = ButtonColor.Success
        };

        var confirmado = await dialog.ShowAsync(
            title: "¿Confirmar cambios?",
            message1: $"¿Estás seguro que quieres actualizar los datos de {usuarioActual.Name}?",
            confirmDialogOptions: opciones);

        if (confirmado)
        {
            var resultado = await usuarioService.ActualizarUsuario(usuarioActual);
            MostrarNotificacion(resultado.title, resultado.msj, resultado.state);
            modoEdicion = false;
        }
    }

    // --- NUEVO: CONFIRMACIÓN PARA BORRAR ---
    private async Task ConfirmarBorrado(Usuario user)
    {
        var opciones = new ConfirmDialogOptions
        {
            YesButtonText = "Sí, eliminar",
            NoButtonText = "No, regresar",
            YesButtonColor = ButtonColor.Danger
        };

        var confirmado = await dialog.ShowAsync(
            title: "¡Advertencia de eliminación!",
            message1: $"¿Estás completamente seguro de eliminar a {user.Name}?",
            message2: "Esta acción no se puede deshacer.",
            confirmDialogOptions: opciones);

        if (confirmado)
        {
            var resultado = await usuarioService.EliminarUsuario(user.Id);
            MostrarNotificacion(resultado.title, resultado.msj, resultado.state);
        }
    }
}