<div class="h-100 bg-gray-950 border-r border-gray-800 transition-all duration-300 flex flex-column @(isCollapsed ? "w-16" : "w-64")">
    
    <div class="h-16 flex items-center justify-center px-4 cursor-pointer hover:bg-gray-900" @onclick="ToggleSidebar">
        <i class="bi bi-list text-white text-2xl"></i>
    </div>

    <nav class="flex flex-column mt-4 gap-2 px-2">
        
        <NavLink class="nav-link-custom" href="" Match="NavLinkMatch.All">
            <i class="bi bi-house-door-fill text-xl"></i>
            <span class="ml-4 transition-opacity duration-300 @(isCollapsed ? "opacity-0 hidden" : "opacity-100")">Inicio</span>
        </NavLink>

        <NavLink class="nav-link-custom" href="gestionador-trabajos">
            <i class="bi bi-list-nested text-xl"></i>
            <span class="ml-4 transition-opacity duration-300 @(isCollapsed ? "opacity-0 hidden" : "opacity-100")">Eventos</span>
        </NavLink>

        <NavLink class="nav-link-custom" href="Authenticacion">
            <i class="bi bi-person-plus-fill text-xl"></i>
            <span class="ml-4 transition-opacity duration-300 @(isCollapsed ? "opacity-0 hidden" : "opacity-100")">Únete</span>
        </NavLink>

        <NavLink class="nav-link-custom" href="gestion">
            <i class="bi bi-people-fill text-xl"></i>
            <span class="ml-4 transition-opacity duration-300 @(isCollapsed ? "opacity-0 hidden" : "opacity-100")">Gestión</span>
        </NavLink>
        <hr />
        <NavLink class="nav-link-custom" href="equipo">
            <i class="bi bi- text-xl"></i>
            <Icon Name="IconName.PersonWorkspace"></Icon>
            <span class="ml-4 transition-opacity duration-300 @(isCollapsed ? "opacity-0 hidden" : "opacity-100")">Equipo</span>
        </NavLink>
        

    </nav>
</div>

@code {
    private bool isCollapsed = true; // Empieza colapsado
    private void ToggleSidebar() => isCollapsed = !isCollapsed;
}

<style>
    .nav-link-custom {
        display: flex;
        align-items: center;
        padding: 0.75rem;
        border-radius: 0.75rem;
        color: #9ca3af;
        text-decoration: none;
        white-space: nowrap; /* Evita que el texto salte de línea */
        transition: all 0.2s;
    }
    .nav-link-custom:hover { background-color: #1f2937; color: white; }
    .nav-link-custom.active { background-color: #2563eb; color: white; }
</style>